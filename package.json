{
  "name": "@kanaka/skim",
  "version": "0.2.0",
  "description": "CLI utility for verbose command summary/capture (head+tail+tee+timeout). With agent skill packaging.",
  "license": "MIT",
  "keywords": [
    "cli",
    "command-output",
    "streaming",
    "agent-skills",
    "skim",
    "head",
    "tail",
    "timeout",
    "tee"
  ],
  "bin": {
    "skim": "skim"
  },
  "files": [
    "skim",
    "skills",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "agents": {
    "skills": [
      {
        "name": "skim",
        "path": "./skills/skim"
      }
    ]
  },
  "scripts": {
    "sync:skill-exec": "sh ./scripts/sync-skill-exec.sh",
    "prepare": "npm run sync:skill-exec",
    "pretest": "npm run sync:skill-exec",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "prepack": "npm test"
  }
}
